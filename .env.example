# Database (Neon Postgres)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/growth_agent?sslmode=require

# Default campaign UUID (from 003_seed_campaign.sql)
DEFAULT_CAMPAIGN_ID=11111111-1111-1111-1111-111111111111

# LLM (OpenRouter) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
APP_URL=https://your-app.com

# Repo intelligence (npm run repo:audit)
# Cheap default: Gemini Flash. GLM-5.2: z-ai/glm-5.2 (see openrouter.ai/models)
REPO_AUDIT_MODEL=openai/gpt-4o-mini

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Growth Agent <outreach@yourdomain.com>
RESEND_REPLY_TO=you@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_...

# Lead enrichment (Apollo)
APOLLO_API_KEY=...

# Notifications
TELEGRAM_BOT_TOKEN=...
OWNER_TELEGRAM_ID=6417265616
CALCOM_BOOKING_URL=https://cal.com/you/15min

# Dashboard
DASHBOARD_SECRET=

# Worker API (optional — secures remote kill switch)
WORKER_API_KEY=

# Scheduler
CRON_ENABLED=true
JOB_BATCH_SIZE=5
PORT=3456

# Set to true for local dev without API keys (uses mock data + example agent outputs)
# Hero product focus (one product until first $)
HERO_PRODUCT_SLUG=hvac-receptionist-agent
HERO_MODE=true

# Set false on Render when Resend + Apollo + OpenRouter keys are configured
MOCK_INTEGRATIONS=true
